{
  "expo": {
    "name": "FIAPP",
    "slug": "FIAPP",
    "version": "1.0.0",
    "scheme": "fiapp",
    "orientation": "portrait",
    "icon": "./src/assets/app-icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./src/assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ED145B"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.asteriuz.FIAPP"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ED145B",
        "foregroundImage": "./src/assets/android-icon-foreground.png",
        "backgroundImage": "./src/assets/android-icon-background.png",
        "monochromeImage": "./src/assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.asteriuz.FIAPP"
    },
    "web": {
      "favicon": "./src/assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "2fd242e8-011f-4932-b27b-d548bfad6a0a"
      }
    },
    "plugins": [
      "expo-router",
      "./src/plugins/withAndroidAutofill.js"
    ]
  }
}